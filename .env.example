# ========================================
# 🎨 pic.christmas - Environment Variables
# ========================================
# INSTRUCCIONES: Copia este archivo como .env.local y completa los valores

# ========================================
# 🎨 AI PROVIDERS (Para generación de imágenes)
# ========================================

# 🏆 REPLICATE (RECOMENDADO - Mejor calidad, 50 gratis/mes)
# Obtener en: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# 🎨 STABILITY AI (Opcional - 25 créditos gratis/mes)
# Obtener en: https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# 🤗 HUGGING FACE (100 gratis/día)
# Obtener en: https://huggingface.co/settings/tokens
HUGGING_FACE_API_KEY=

# 🧠 GOOGLE AI STUDIO (60/min gratis)
# Obtener en: https://makersuite.google.com/app/apikey
GOOGLE_AI_STUDIO_API_KEY=

# 🚀 SEGMIND (100 créditos/mes gratis)
# Obtener en: https://www.segmind.com/
SEGMIND_API_KEY=

# ========================================
# 💾 SUPABASE (Storage & Database)
# ========================================
# Obtener en: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ========================================
# 💳 STRIPE (Payments)
# ========================================
# Obtener en: https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ========================================
# 🚦 UPSTASH REDIS (Rate Limiting)
# ========================================
# Obtener en: https://console.upstash.com/

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ========================================
# 📧 RESEND (Email)
# ========================================
# Obtener en: https://resend.com/api-keys

RESEND_API_KEY=

# ========================================
# 🔐 CLERK (Authentication - Opcional)
# ========================================
# Obtener en: https://dashboard.clerk.com/

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ========================================
# 🌐 SITE CONFIG
# ========================================

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
